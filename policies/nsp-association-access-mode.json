{
  "if": {
    "allOf": [
      {
        "field": "type",
        "equals": "Microsoft.Network/networkSecurityPerimeters/resourceAssociations"
      },
      {
        "field": "Microsoft.Network/networkSecurityPerimeters/resourceAssociations/accessMode",
        "notEquals": "Enforced"
      }
    ]
  },
  "then": {
    "effect": "[parameters('effect')]"
  }
}
