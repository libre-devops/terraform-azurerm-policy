{
  "if": {
    "field": "type",
    "equals": "Microsoft.Storage/storageAccounts"
  },
  "then": {
    "effect": "[parameters('effect')]",
    "details": {
      "type": "Microsoft.Storage/storageAccounts/networkSecurityPerimeterConfigurations",
      "existenceCondition": {
        "field": "Microsoft.Storage/storageAccounts/networkSecurityPerimeterConfigurations/networkSecurityPerimeter.id",
        "in": "[parameters('approvedPerimeterIds')]"
      }
    }
  }
}
